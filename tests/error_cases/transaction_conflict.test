# Transaction Conflict Tests

# Setup
statement ok
CREATE TABLE test_account (
    id INT PRIMARY KEY,
    balance INT
)

statement ok
INSERT INTO test_account VALUES (1, 1000), (2, 500)

# Test 001: Deadlock detection
statement ok
BEGIN

statement ok
UPDATE test_account SET balance = balance - 100 WHERE id = 1

# Simulate concurrent transaction (would deadlock in real scenario)
statement ok
UPDATE test_account SET balance = balance + 100 WHERE id = 2

statement ok
COMMIT

# Test 002: Write conflict
statement ok
BEGIN

statement ok
UPDATE test_account SET balance = balance - 200 WHERE id = 1

# Another transaction updates same row
statement ok
UPDATE test_account SET balance = balance - 300 WHERE id = 1

statement ok
COMMIT

# Cleanup
statement ok
DROP TABLE test_account
